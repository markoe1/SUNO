# WhopClipper Environment Variables
# ===================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# Whop Credentials
WHOP_EMAIL=your_whop_email@example.com
WHOP_PASSWORD=your_whop_password

# TikTok Credentials
TIKTOK_USERNAME=your_tiktok_username
TIKTOK_PASSWORD=your_tiktok_password

# Instagram Credentials
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# YouTube/Google Credentials
YOUTUBE_EMAIL=your_youtube_email@gmail.com
YOUTUBE_PASSWORD=your_youtube_password

# Stripe (payments — leave blank until billing is ready)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:5001/success
STRIPE_CANCEL_URL=http://localhost:5001/cancel
STRIPE_WEBHOOK_SECRET=
