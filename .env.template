# VyroClipper Environment Variables
# ==================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# Vyro Credentials
VYRO_EMAIL=your_vyro_email@example.com
VYRO_PASSWORD=your_vyro_password

# TikTok Credentials
TIKTOK_USERNAME=your_tiktok_username
TIKTOK_PASSWORD=your_tiktok_password

# Instagram Credentials
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# YouTube/Google Credentials
YOUTUBE_EMAIL=your_youtube_email@gmail.com
YOUTUBE_PASSWORD=your_youtube_password

# Facebook Credentials
FACEBOOK_EMAIL=your_facebook_email
FACEBOOK_PASSWORD=your_facebook_password

# X/Twitter Credentials (optional)
X_USERNAME=your_x_username
X_PASSWORD=your_x_password

# Stripe (payments)
STRIPE_SECRET_KEY=sk_live_or_test_key_here
STRIPE_PRICE_ID_SUNO=sunoprice_123456   # Checkout price for SUNO
STRIPE_SUCCESS_URL=http://localhost:5001/success
STRIPE_CANCEL_URL=http://localhost:5001/cancel
STRIPE_WEBHOOK_SECRET=whsec_xxx   # optional, for future use
