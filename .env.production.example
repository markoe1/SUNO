# SUNO Production Environment
# Copy to .env and fill in actual values

# === REQUIRED ===
WHOP_API_KEY=apik_YOUR_KEY_HERE
WHOP_COMPANY_ID=biz_YOUR_COMPANY_ID

# YouTube API (OAuth)
# Get from: https://console.cloud.google.com
# Follow: youtube_uploader/YOUTUBE_SETUP.md
# File: youtube_uploader/credentials.json (auto-generates token.pickle)

# Anthropic API (for captions if implemented)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# === DATABASE ===
DATABASE_URL=sqlite:///./data/whop_clips.db

# === OPTIONAL (for TikTok/Instagram browser automation) ===
TIKTOK_USERNAME=your_tiktok_email@example.com
TIKTOK_PASSWORD=your_tiktok_password

INSTAGRAM_USERNAME=your_instagram_email@example.com
INSTAGRAM_PASSWORD=your_instagram_password

# === APP CONFIG ===
APP_ENV=production
LOG_LEVEL=INFO
DEBUG=false

# === POSTING CONFIG ===
HEADLESS=true
BROWSER_TIMEOUT=30
DAILY_CLIP_TARGET=100
CLIPS_PER_SESSION=20
SESSIONS_PER_DAY=0

# === SAFETY ===
MIN_QUALITY_SCORE=70
MAX_POST_RETRIES=2
RATE_LIMIT_COOLDOWN=15
