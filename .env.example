# Database
# Dev: postgresql+asyncpg://suno:suno@localhost:5432/suno_clips
# Prod: Update to your production PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://suno:suno@db:5432/suno_clips

# Redis
# Dev: redis://localhost:6379/0
# Prod: Update to your production Redis URL (e.g., Upstash, Redis Cloud)
REDIS_URL=redis://redis:6379/0

# Security
ENCRYPTION_KEY=          # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_SECRET_KEY=          # generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_REFRESH_SECRET_KEY=  # generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_COOKIE_SECRET=   # generate: python -c "import secrets; print(secrets.token_hex(32))"

# App
# Set to "production" when deploying (enables secure cookies, disables /docs)
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Update to your production domain (used for webhooks + CORS)
BASE_URL=http://localhost:8000

# AI (hook generator)
ANTHROPIC_API_KEY=           # get from console.anthropic.com

# Email (Resend — https://resend.com)
RESEND_API_KEY=              # get from resend.com → API Keys
EMAIL_FROM=SUNO Clips <no-reply@sunoclips.io>   # must be from a verified Resend domain

# Whop Billing (operator subscriptions)
WHOP_API_KEY=                # from dashboard.whop.com → API Keys (also used for session validation)
WHOP_API_BASE=https://api.whop.com  # official Whop Developer API base
WHOP_WEBHOOK_SECRET=         # from dashboard.whop.com → Webhooks
WHOP_PRODUCT_ID=             # prod_xxx from your Whop product page
# Use BASE_URL for production
SUCCESS_URL=http://localhost:8000/success
CANCEL_URL=http://localhost:8000/cancel
# Prod: Add your production domain here (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:8000

# Whop Clipping API
WHOP_BASE_URL=https://whop.com
# Clipping API paths — these are undocumented internal endpoints.
# If submissions return 404, capture the real paths from DevTools Network tab
# while submitting a clip manually on whop.com, then update these.
WHOP_CAMPAIGNS_PATH=/api/v5/clipping/campaigns
WHOP_SUBMIT_PATH=/api/v5/clipping/campaigns/{campaign_id}/submissions
WHOP_CHECK_PATH=/api/v5/clipping/submissions/{submission_id}

# Platform performance fetching
YOUTUBE_API_KEY=             # get from console.cloud.google.com (YouTube Data API v3)
# TikTok and Instagram require OAuth per-account tokens (see workers/tasks/fetch_performance.py)

# Internal API key for cron-triggered endpoints (e.g. /api/invoices/run-monthly)
INTERNAL_API_KEY=            # generate: python -c "import secrets; print(secrets.token_hex(32))"

# Workers
WORKER_CONCURRENCY=2
JOB_TIMEOUT=300
MAX_RETRIES=3
RETRY_BACKOFF_BASE=60

# Rate limiting
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_SUBMISSIONS=20/minute

# Whop automation delays (seconds)
WHOP_REQUEST_DELAY_MIN=2
WHOP_REQUEST_DELAY_MAX=5
