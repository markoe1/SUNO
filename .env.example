# Database
DATABASE_URL=postgresql+asyncpg://suno:suno@localhost:5432/suno_clips

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
ENCRYPTION_KEY=          # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_SECRET_KEY=          # generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_REFRESH_SECRET_KEY=  # generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_COOKIE_SECRET=   # generate: python -c "import secrets; print(secrets.token_hex(32))"

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost:8000

# Whop
WHOP_BASE_URL=https://whop.com

# Workers
WORKER_CONCURRENCY=2
JOB_TIMEOUT=300
MAX_RETRIES=3
RETRY_BACKOFF_BASE=60

# Rate limiting
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_SUBMISSIONS=20/minute

# Whop automation delays (seconds)
WHOP_REQUEST_DELAY_MIN=2
WHOP_REQUEST_DELAY_MAX=5
